# Tenant / white-label
# Selecciona el tenant activo del registro en config/tenants.js (un deploy por tenant).
# Setear AMBOS: TENANT lo usa el server y next.config.js; NEXT_PUBLIC_TENANT el cliente.
# NEXT_PUBLIC_TENANT se hornea en build (next build) — cambiar de tenant requiere rebuild.
# Valores disponibles: limefit (default) | level
TENANT=limefit
NEXT_PUBLIC_TENANT=limefit

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/limefit

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-change-in-production

# Generate a secret with: openssl rand -base64 32
